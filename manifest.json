{
    "manifest_version": 3,
    "name": "Edvibe Toolbox",
    "version": "1.0",
    "description": "A universal toolkit for automation and backup on the Edvibe platform.",
    "permissions": [
        "storage",
        "activeTab"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.edvibe.com/*"
            ],
            "js": [
                "isolated.js"
            ],
            "run_at": "document_start"
        },
        {
            "matches": [
                "*://*.edvibe.com/*"
            ],
            "js": [
                "lib/jszip.min.js",
                "lib/turndown.min.js",
                "compileMarathonToZip.js",
                "resetLessons.js",
                "main.js"
            ],
            "run_at": "document_start",
            "world": "MAIN"
        }
    ]
}
